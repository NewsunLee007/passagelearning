  "sentences": [
    {
      "id": "u14-s1",
      "text": "At last, I arrived in Chengdu.",
      "paragraphId": "u14-p1",
      "keywords": [
        "arrived",
        "Chengdu"
      ]
    },
    {
      "id": "u14-s2",
      "text": "My friend Haoyu took me to a restaurant right from the airport.",
      "paragraphId": "u14-p1",
      "keywords": [
        "friend",
        "restaurant",
        "airport"
      ]
    },
    {
      "id": "u14-s3",
      "text": "I just couldn't wait to try Sichuan hot pot!",
      "paragraphId": "u14-p1",
      "keywords": [
        "couldn't wait",
        "Sichuan hot pot"
      ]
    },
    {
      "id": "u14-s4",
      "text": "But the first taste made my mouth burn!",
      "paragraphId": "u14-p2",
      "keywords": [
        "first taste",
        "mouth burn"
      ]
    },
    {
      "id": "u14-s5",
      "text": "The food was much hotter than I expected.",
      "paragraphId": "u14-p2",
      "keywords": [
        "much hotter",
        "expected"
      ]
    },
    {
      "id": "u14-s6",
      "text": "I took a deep breath and drank a whole glass of iced lemon tea.",
      "paragraphId": "u14-p2",
      "keywords": [
        "deep breath",
        "iced lemon tea"
      ]
    },
    {
      "id": "u14-s7",
      "text": "\"Do you want something less hot?\" Haoyu said.",
      "paragraphId": "u14-p2",
      "keywords": [
        "something less hot"
      ]
    },
    {
      "id": "u14-s8",
      "text": "\"No,\" I replied.",
      "paragraphId": "u14-p2",
      "keywords": [
        "replied"
      ]
    },
    {
      "id": "u14-s9",
      "text": "\"When in China, do as the Chinese do!\"",
      "paragraphId": "u14-p3",
      "keywords": [
        "When in China",
        "do as the Chinese do"
      ]
    },
    {
      "id": "u14-s10",
      "text": "I carefully took a small mouthful.",
      "paragraphId": "u14-p3",
      "keywords": [
        "carefully",
        "small mouthful"
      ]
    },
    {
      "id": "u14-s11",
      "text": "Surprisingly, I started to enjoy the taste.",
      "paragraphId": "u14-p3",
      "keywords": [
        "Surprisingly",
        "enjoy the taste"
      ]
    },
    {
      "id": "u14-s12",
      "text": "And cooking hot pot was just as fun as eating it!",
      "paragraphId": "u14-p3",
      "keywords": [
        "cooking hot pot",
        "just as fun"
      ]
    },
    {
      "id": "u14-s13",
      "text": "After lunch, things went from really hot to totally cool - we went to the new Sanxingdui Museum!",
      "paragraphId": "u14-p3",
      "keywords": [
        "really hot",
        "totally cool",
        "Sanxingdui Museum"
      ]
    },
    {
      "id": "u14-s14",
      "text": "The masks were fantastic.",
      "paragraphId": "u14-p4",
      "keywords": [
        "masks",
        "fantastic"
      ]
    },
    {
      "id": "u14-s15",
      "text": "\"Why are their eyes and ears much bigger than normal ones? Were ancient Shu people able to see and hear further than us?\" I wondered.",
      "paragraphId": "u14-p4",
      "keywords": [
        "eyes and ears",
        "ancient Shu people",
        "see and hear"
      ]
    },
    {
      "id": "u14-s16",
      "text": "I wanted to stay in the museum for a week!",
      "paragraphId": "u14-p4",
      "keywords": [
        "stay",
        "museum",
        "week"
      ]
    },
    {
      "id": "u14-s17",
      "text": "My first day in China was full of fun: I tried new food and went to an exciting place.",
      "paragraphId": "u14-p4",
      "keywords": [
        "first day",
        "full of fun",
        "exciting place"
      ]
    },
    {
      "id": "u14-s18",
      "text": "I'm really looking forward to the rest of my trip around China!",
      "paragraphId": "u14-p4",
      "keywords": [
        "looking forward",
        "trip around China"
      ]
    }
  ],
