  "readingQuestions": [
    {
      "id": "reading-q1",
      "type": "single_choice",
      "stem": "What is the main idea of the passage?",
      "options": [
        "A. How to survive on an island",
        "B. The importance of having fun",
        "C. Famous quotes about playing",
        "D. How to make friends"
      ],
      "answer": "B. The importance of having fun",
      "rationaleZh": "文章通篇强调乐趣（Fun）在心理、社交和保持年轻方面的重要性。"
    },
    {
      "id": "reading-q2",
      "type": "single_choice",
      "stem": "According to paragraph 2, fun can help us ______.",
      "options": [
        "A. find food",
        "B. watch films",
        "C. lift our spirits",
        "D. plant trees"
      ],
      "answer": "C. lift our spirits",
      "rationaleZh": "第二段明确提到：Fun can... lift our spirits。"
    },
    {
      "id": "reading-q3",
      "type": "single_choice",
      "stem": "What does George Bernard Shaw think about playing?",
      "options": [
        "A. It's only for kids",
        "B. It makes us grow old",
        "C. It keeps us from growing old",
        "D. It's a waste of time"
      ],
      "answer": "C. It keeps us from growing old",
      "rationaleZh": "萧伯纳认为我们是因为停止玩耍才变老的，所以玩耍能让我们保持年轻。"
    },
    {
      "id": "reading-q4",
      "type": "single_choice",
      "stem": "The phrase 'do away with' in paragraph 2 means ______.",
      "options": [
        "A. get rid of",
        "B. put up with",
        "C. keep up with",
        "D. come up with"
      ],
      "answer": "A. get rid of",
      "rationaleZh": "do away with 意为消除、废除，与 get rid of 意思相近。"
    },
    {
      "id": "reading-q5",
      "type": "single_choice",
      "stem": "Which of the following is TRUE according to the text?",
      "options": [
        "A. Fun brings people closer",
        "B. Work is more important than fun",
        "C. We should only play on islands",
        "D. Music is the only way to have fun"
      ],
      "answer": "A. Fun brings people closer",
      "rationaleZh": "第四段明确提到：Research also shows that fun brings people closer。"
    }
  ],
