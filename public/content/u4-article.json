  "sentenceTasks": [],
  "readingQuestions": [
    {
      "id": "reading-q1",
      "type": "single_choice",
      "stem": "Why did people laugh at Zhou Jian?",
      "options": [
        "A. Because he wore a funny hat.",
        "B. Because he had very long hair like a girl.",
        "C. Because he was very short.",
        "D. Because he talked to himself."
      ],
      "answer": "B. Because he had very long hair like a girl.",
      "rationaleZh": "文章第一、二段提到，因为他留着长发，别人分不清他是男是女，并在背后嘲笑他。"
    },
    {
      "id": "reading-q2",
      "type": "single_choice",
      "stem": "Why did Zhou Jian keep his hair long for over two years?",
      "options": [
        "A. He wanted to be a rock star.",
        "B. He didn't have money for a haircut.",
        "C. He wanted to donate his hair to help kids with cancer.",
        "D. He liked long hair very much."
      ],
      "answer": "C. He wanted to donate his hair to help kids with cancer.",
      "rationaleZh": "文章第五段的信中提到：'Thank you for helping kids with cancer. This is enough hair for three wigs!' 说明他留长发是为了捐赠给患癌儿童做假发。"
    },
    {
      "id": "reading-q3",
      "type": "single_choice",
      "stem": "How did Zhou Jian feel when people laughed at him?",
      "options": [
        "A. He felt very angry.",
        "B. He felt sad and cried.",
        "C. He never felt any shame.",
        "D. He wanted to fight with them."
      ],
      "answer": "C. He never felt any shame.",
      "rationaleZh": "文章第二段明确写道：'But he never felt any shame.'（但他从未感到羞耻。）"
    },
    {
      "id": "reading-q4",
      "type": "single_choice",
      "stem": "What is the main idea of this story?",
      "options": [
        "A. How to grow long hair.",
        "B. A famous barber shop.",
        "C. Happiness comes from doing good and helping others.",
        "D. A letter from a hospital."
      ],
      "answer": "C. Happiness comes from doing good and helping others.",
      "rationaleZh": "文章最后引用柏拉图的话点明了主旨：'Happiness springs from doing good and helping others.'（幸福源于行善和助人。）"
    },
    {
      "id": "reading-q5",
      "type": "single_choice",
      "stem": "Who sent the letter to Zhou Jian?",
      "options": [
        "A. The barber.",
        "B. A sick child.",
        "C. The City Children's Hospital.",
        "D. His teacher."
      ],
      "answer": "C. The City Children's Hospital.",
      "rationaleZh": "信件的落款显示来自 'The City Children's Hospital'（市儿童医院）。"
    }
  ],
