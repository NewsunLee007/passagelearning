  "sentences": [
    {
      "id": "u4-s1",
      "text": "The wind was strong.",
      "paragraphId": "u4-p1",
      "keywords": [
        "wind",
        "strong"
      ]
    },
    {
      "id": "u4-s2",
      "text": "Zhou Jian's hat blew off.",
      "paragraphId": "u4-p1",
      "keywords": [
        "hat",
        "blew off"
      ]
    },
    {
      "id": "u4-s3",
      "text": "His long hair waved in the air.",
      "paragraphId": "u4-p1",
      "keywords": [
        "long hair",
        "waved",
        "air"
      ]
    },
    {
      "id": "u4-s4",
      "text": "He heard a voice behind him: \"Is that a boy or a girl?\"",
      "paragraphId": "u4-p1",
      "keywords": [
        "heard",
        "voice",
        "behind"
      ]
    },
    {
      "id": "u4-s5",
      "text": "He shook his head.",
      "paragraphId": "u4-p1",
      "keywords": [
        "shook",
        "head"
      ]
    },
    {
      "id": "u4-s6",
      "text": "\"Just one more month!\" he said to himself.",
      "paragraphId": "u4-p1",
      "keywords": [
        "month",
        "said",
        "himself"
      ]
    },
    {
      "id": "u4-s7",
      "text": "People often talked about his long hair behind his back.",
      "paragraphId": "u4-p2",
      "keywords": [
        "talked about",
        "behind his back"
      ]
    },
    {
      "id": "u4-s8",
      "text": "Sometimes they laughed at him.",
      "paragraphId": "u4-p2",
      "keywords": [
        "laughed at"
      ]
    },
    {
      "id": "u4-s9",
      "text": "But he never felt any shame.",
      "paragraphId": "u4-p2",
      "keywords": [
        "never",
        "felt",
        "shame"
      ]
    },
    {
      "id": "u4-s10",
      "text": "Zhou Jian kept his hair long for over two years.",
      "paragraphId": "u4-p3",
      "keywords": [
        "kept",
        "long",
        "over two years"
      ]
    },
    {
      "id": "u4-s11",
      "text": "Day after day, hope grew together with his hair.",
      "paragraphId": "u4-p3",
      "keywords": [
        "Day after day",
        "hope",
        "grew"
      ]
    },
    {
      "id": "u4-s12",
      "text": "Finally, the time came.",
      "paragraphId": "u4-p4",
      "keywords": [
        "Finally",
        "time",
        "came"
      ]
    },
    {
      "id": "u4-s13",
      "text": "Zhou Jian walked into a barber's shop.",
      "paragraphId": "u4-p4",
      "keywords": [
        "walked into",
        "barber's shop"
      ]
    },
    {
      "id": "u4-s14",
      "text": "He took off his hat and his hair fell around his shoulders.",
      "paragraphId": "u4-p4",
      "keywords": [
        "took off",
        "fell",
        "shoulders"
      ]
    },
    {
      "id": "u4-s15",
      "text": "The other customers were very surprised.",
      "paragraphId": "u4-p4",
      "keywords": [
        "customers",
        "surprised"
      ]
    },
    {
      "id": "u4-s16",
      "text": "\"Please cut it short and give me the hair,\" he said.",
      "paragraphId": "u4-p4",
      "keywords": [
        "cut",
        "short",
        "give"
      ]
    },
    {
      "id": "u4-s17",
      "text": "The barber's scissors did their work.",
      "paragraphId": "u4-p4",
      "keywords": [
        "barber's scissors",
        "did their work"
      ]
    },
    {
      "id": "u4-s18",
      "text": "Zhou Jian carefully put the hair into a bag and walked to the post office.",
      "paragraphId": "u4-p4",
      "keywords": [
        "carefully",
        "put",
        "bag",
        "post office"
      ]
    },
    {
      "id": "u4-s19",
      "text": "A week later, he received a letter:",
      "paragraphId": "u4-p5",
      "keywords": [
        "week later",
        "received",
        "letter"
      ]
    }
  ],
