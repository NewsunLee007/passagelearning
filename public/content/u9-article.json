  "readingQuestions": [
    {
      "id": "reading-q1",
      "type": "single_choice",
      "stem": "Where did ice cream originally come from according to the text?",
      "options": [
        "A. Europe",
        "B. America",
        "C. China",
        "D. Iran"
      ],
      "answer": "C. China",
      "rationaleZh": "文中明确提到 'this sweet treat actually came from China!'"
    },
    {
      "id": "reading-q2",
      "type": "single_choice",
      "stem": "Who is said to have brought the idea of binglao to Europe?",
      "options": [
        "A. Emperor Huizong",
        "B. Marco Polo",
        "C. Iranians",
        "D. Venezuelans"
      ],
      "answer": "B. Marco Polo",
      "rationaleZh": "文中提到 'Marco Polo tasted binglao and carried the idea all the way back to Europe.'"
    },
    {
      "id": "reading-q3",
      "type": "single_choice",
      "stem": "Which food is described as the 'twin brother' of roujiamo?",
      "options": [
        "A. Hamburger",
        "B. Sangak",
        "C. Stone pancake",
        "D. Arepas"
      ],
      "answer": "D. Arepas",
      "rationaleZh": "文中提到 'arepas of Venezuela look more like the twin brother of roujiamo!'"
    },
    {
      "id": "reading-q4",
      "type": "single_choice",
      "stem": "What did people in the Zhou Dynasty do with ice?",
      "options": [
        "A. Made ice cream",
        "B. Stored it for summer",
        "C. Sold it to Europe",
        "D. Used it for medicine"
      ],
      "answer": "B. Stored it for summer",
      "rationaleZh": "文中提到 'In the Zhou Dynasty, Chinese people began to store winter ice to enjoy in summer.'"
    },
    {
      "id": "reading-q5",
      "type": "single_choice",
      "stem": "What is the main idea of the last paragraph?",
      "options": [
        "A. Food is expensive",
        "B. Food connects different cultures",
        "C. We should only eat local food",
        "D. History is simple"
      ],
      "answer": "B. Food connects different cultures",
      "rationaleZh": "最后一段总结道 'Food is a bridge between cultures.'"
    }
  ],
