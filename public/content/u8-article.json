  "sentences": [
    {
      "id": "u8-s1",
      "text": "The taste and smell of a certain food can often bring back memories.",
      "paragraphId": "u8-p1",
      "keywords": [
        "taste",
        "smell",
        "bring back",
        "memories"
      ]
    },
    {
      "id": "u8-s2",
      "text": "Mine start with my mother.",
      "paragraphId": "u8-p2",
      "keywords": [
        "mine",
        "start with",
        "mother"
      ]
    },
    {
      "id": "u8-s3",
      "text": "She can do magic in the kitchen: tofu and beef become red, hot mapo tofu; carrots and mutton become lovely dumplings; a big fat hen becomes a pot of warm chicken soup; even eggs and green onions become wonderful pancakes.",
      "paragraphId": "u8-p2",
      "keywords": [
        "do magic",
        "kitchen",
        "mapo tofu",
        "dumplings",
        "chicken soup",
        "pancakes"
      ]
    },
    {
      "id": "u8-s4",
      "text": "I always grow hungry thinking of them!",
      "paragraphId": "u8-p2",
      "keywords": [
        "grow hungry",
        "thinking of"
      ]
    },
    {
      "id": "u8-s5",
      "text": "But my favourite food is porridge.",
      "paragraphId": "u8-p2",
      "keywords": [
        "favourite",
        "porridge"
      ]
    },
    {
      "id": "u8-s6",
      "text": "I often wake up to the smell of porridge.",
      "paragraphId": "u8-p2",
      "keywords": [
        "wake up",
        "smell"
      ]
    },
    {
      "id": "u8-s7",
      "text": "Sometimes, it's sweet eight-treasure porridge.",
      "paragraphId": "u8-p3",
      "keywords": [
        "sometimes",
        "sweet",
        "eight-treasure porridge"
      ]
    },
    {
      "id": "u8-s8",
      "text": "Other times, it's porridge with pork and thousand-year-old eggs.",
      "paragraphId": "u8-p3",
      "keywords": [
        "other times",
        "pork",
        "thousand-year-old eggs"
      ]
    },
    {
      "id": "u8-s9",
      "text": "Each kind of porridge tastes great in its own way.",
      "paragraphId": "u8-p3",
      "keywords": [
        "each kind",
        "tastes great",
        "in its own way"
      ]
    },
    {
      "id": "u8-s10",
      "text": "When I fall ill, my mother always makes plain rice porridge for me.",
      "paragraphId": "u8-p3",
      "keywords": [
        "fall ill",
        "makes",
        "plain rice porridge"
      ]
    },
    {
      "id": "u8-s11",
      "text": "That's the simplest food on any Chinese menu.",
      "paragraphId": "u8-p4",
      "keywords": [
        "simplest",
        "Chinese menu"
      ]
    },
    {
      "id": "u8-s12",
      "text": "For me, however, it's the best food in the world.",
      "paragraphId": "u8-p4",
      "keywords": [
        "best",
        "in the world"
      ]
    },
    {
      "id": "u8-s13",
      "text": "And it's better medicine than a pill!",
      "paragraphId": "u8-p4",
      "keywords": [
        "better",
        "medicine",
        "pill"
      ]
    },
    {
      "id": "u8-s14",
      "text": "Now I'm studying away from home.",
      "paragraphId": "u8-p5",
      "keywords": [
        "studying",
        "away from home"
      ]
    },
    {
      "id": "u8-s15",
      "text": "But all the warm memories stay with me.",
      "paragraphId": "u8-p5",
      "keywords": [
        "warm memories",
        "stay with"
      ]
    },
    {
      "id": "u8-s16",
      "text": "The old days still feel so sweet in my heart.",
      "paragraphId": "u8-p5",
      "keywords": [
        "old days",
        "feel",
        "sweet",
        "heart"
      ]
    },
    {
      "id": "u8-s17",
      "text": "What food remains strong in your memory?",
      "paragraphId": "u8-p5",
      "keywords": [
        "remains",
        "strong",
        "memory"
      ]
    }
  ],
