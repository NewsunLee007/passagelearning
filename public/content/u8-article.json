  "readingQuestions": [
    {
      "id": "reading-q1",
      "type": "single_choice",
      "stem": "What is the passage mainly about?",
      "options": [
        "A. How to cook Chinese food",
        "B. Food memories and mother's love",
        "C. Different kinds of porridge",
        "D. Life away from home"
      ],
      "answer": "B. Food memories and mother's love",
      "rationaleZh": "主旨大意题。文章通过描述母亲做的各种食物，特别是粥，表达了对母亲和家的思念。"
    },
    {
      "id": "reading-q2",
      "type": "single_choice",
      "stem": "What does the mother make when the writer is ill?",
      "options": [
        "A. Mapo tofu",
        "B. Chicken soup",
        "C. Plain rice porridge",
        "D. Dumplings"
      ],
      "answer": "C. Plain rice porridge",
      "rationaleZh": "细节理解题。文中提到 'When I fall ill, my mother always makes plain rice porridge for me.'"
    },
    {
      "id": "reading-q3",
      "type": "single_choice",
      "stem": "Which food is NOT mentioned as part of mother's magic?",
      "options": [
        "A. Pizza",
        "B. Dumplings",
        "C. Pancakes",
        "D. Chicken soup"
      ],
      "answer": "A. Pizza",
      "rationaleZh": "细节理解题。文中提到了饺子、煎饼和鸡汤，没有提到披萨。"
    },
    {
      "id": "reading-q4",
      "type": "single_choice",
      "stem": "Why does the writer think plain rice porridge is better than a pill?",
      "options": [
        "A. It is cheaper",
        "B. It tastes sweet",
        "C. It is full of love and comfort",
        "D. It has medicine in it"
      ],
      "answer": "C. It is full of love and comfort",
      "rationaleZh": "推理判断题。作者认为它是世界上最好的食物，因为它包含了母亲的爱和关怀，能带来安慰。"
    },
    {
      "id": "reading-q5",
      "type": "single_choice",
      "stem": "What does the word 'plain' mean in 'plain rice porridge'?",
      "options": [
        "A. Ugly",
        "B. Simple, without added ingredients",
        "C. Expensive",
        "D. Cold"
      ],
      "answer": "B. Simple, without added ingredients",
      "rationaleZh": "词义猜测题。Plain 在这里意为'清淡的，简单的'，即没有添加复杂配料的白粥。"
    }
  ],
