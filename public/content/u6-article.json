  "sentences": [
    {
      "id": "u6-s1",
      "text": "It was the last minute of the 2022 Beijing Marathon.",
      "paragraphId": "u6-p1",
      "keywords": [
        "last minute",
        "Beijing Marathon"
      ]
    },
    {
      "id": "u6-s2",
      "text": "However, 86-year-old Zhang Shun was still about 100 metres from the finishing line.",
      "paragraphId": "u6-p1",
      "keywords": [
        "86-year-old",
        "finishing line"
      ]
    },
    {
      "id": "u6-s3",
      "text": "People watched him move slowly.",
      "paragraphId": "u6-p1",
      "keywords": [
        "move slowly"
      ]
    },
    {
      "id": "u6-s4",
      "text": "All of them held their breath.",
      "paragraphId": "u6-p1",
      "keywords": [
        "held their breath"
      ]
    },
    {
      "id": "u6-s5",
      "text": "Would he make it?",
      "paragraphId": "u6-p1",
      "keywords": [
        "make it"
      ]
    },
    {
      "id": "u6-s6",
      "text": "Zhang felt confident before the race.",
      "paragraphId": "u6-p2",
      "keywords": [
        "confident",
        "before the race"
      ]
    },
    {
      "id": "u6-s7",
      "text": "But he had a stomachache on the way.",
      "paragraphId": "u6-p2",
      "keywords": [
        "stomachache",
        "on the way"
      ]
    },
    {
      "id": "u6-s8",
      "text": "This made him fall behind.",
      "paragraphId": "u6-p2",
      "keywords": [
        "fall behind"
      ]
    },
    {
      "id": "u6-s9",
      "text": "\"Shall I take a rest or stop?\" he thought.",
      "paragraphId": "u6-p2",
      "keywords": [
        "take a rest",
        "stop"
      ]
    },
    {
      "id": "u6-s10",
      "text": "Either choice seemed fine for someone at his age.",
      "paragraphId": "u6-p2",
      "keywords": [
        "either choice",
        "at his age"
      ]
    },
    {
      "id": "u6-s11",
      "text": "But Zhang chose neither of them.",
      "paragraphId": "u6-p2",
      "keywords": [
        "chose neither"
      ]
    },
    {
      "id": "u6-s12",
      "text": "He just ran on.",
      "paragraphId": "u6-p2",
      "keywords": [
        "ran on"
      ]
    },
    {
      "id": "u6-s13",
      "text": "With people cheering, he finally crossed the finishing line!",
      "paragraphId": "u6-p2",
      "keywords": [
        "cheering",
        "crossed the finishing line"
      ]
    },
    {
      "id": "u6-s14",
      "text": "Marathon running is Zhang's lifelong dream.",
      "paragraphId": "u6-p3",
      "keywords": [
        "lifelong dream"
      ]
    },
    {
      "id": "u6-s15",
      "text": "\"In 1989, I saw Beijing Marathon runners go past my home.",
      "paragraphId": "u6-p3",
      "keywords": [
        "go past"
      ]
    },
    {
      "id": "u6-s16",
      "text": "I just wanted to become one of them,\" he said.",
      "paragraphId": "u6-p3",
      "keywords": [
        "become one of them"
      ]
    },
    {
      "id": "u6-s17",
      "text": "For years, he trained every morning in the park.",
      "paragraphId": "u6-p4",
      "keywords": [
        "trained",
        "every morning"
      ]
    },
    {
      "id": "u6-s18",
      "text": "He filled over 30 notebooks with his running records.",
      "paragraphId": "u6-p4",
      "keywords": [
        "filled",
        "running records"
      ]
    },
    {
      "id": "u6-s19",
      "text": "None of his family members worried or tried to stop him.",
      "paragraphId": "u6-p4",
      "keywords": [
        "worried",
        "stop him"
      ]
    },
    {
      "id": "u6-s20",
      "text": "They knew he enjoyed every moment.",
      "paragraphId": "u6-p4",
      "keywords": [
        "enjoyed every moment"
      ]
    },
    {
      "id": "u6-s21",
      "text": "Zhang Shun was the oldest and the slowest runner to finish the 2022 Beijing Marathon.",
      "paragraphId": "u6-p5",
      "keywords": [
        "oldest",
        "slowest runner"
      ]
    },
    {
      "id": "u6-s22",
      "text": "But it didn't matter to him.",
      "paragraphId": "u6-p5",
      "keywords": [
        "didn't matter"
      ]
    },
    {
      "id": "u6-s23",
      "text": "For Zhang, running isn't about winning - it's about enjoying the sport itself.",
      "paragraphId": "u6-p5",
      "keywords": [
        "about winning",
        "enjoying the sport"
      ]
    },
    {
      "id": "u6-s24",
      "text": "He has no plans to stop.",
      "paragraphId": "u6-p5",
      "keywords": [
        "no plans to stop"
      ]
    },
    {
      "id": "u6-s25",
      "text": "\"If possible, I will keep running.\"",
      "paragraphId": "u6-p5",
      "keywords": [
        "keep running"
      ]
    }
  ],
