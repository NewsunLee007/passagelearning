  "sentences": [
    {
      "id": "u12-s1",
      "text": "My hometown is on the Qinghai-Tibet Plateau.",
      "paragraphId": "u12-p1",
      "keywords": [
        "hometown",
        "Qinghai-Tibet Plateau"
      ]
    },
    {
      "id": "u12-s2",
      "text": "The geography here is amazing.",
      "paragraphId": "u12-p1",
      "keywords": [
        "geography",
        "amazing"
      ]
    },
    {
      "id": "u12-s3",
      "text": "It is famous for the world's highest mountain.",
      "paragraphId": "u12-p1",
      "keywords": [
        "famous",
        "highest mountain"
      ]
    },
    {
      "id": "u12-s4",
      "text": "But this area is also full of the most amazing colours in nature.",
      "paragraphId": "u12-p1",
      "keywords": [
        "area",
        "amazing colours",
        "nature"
      ]
    },
    {
      "id": "u12-s5",
      "text": "The colour white meets your eyes all around.",
      "paragraphId": "u12-p2",
      "keywords": [
        "white",
        "meets",
        "eyes"
      ]
    },
    {
      "id": "u12-s6",
      "text": "The clouds are clean and soft, like our white sheep.",
      "paragraphId": "u12-p2",
      "keywords": [
        "clouds",
        "clean",
        "soft",
        "white sheep"
      ]
    },
    {
      "id": "u12-s7",
      "text": "The mountains shine brightly in the sun, like white sea waves.",
      "paragraphId": "u12-p2",
      "keywords": [
        "mountains",
        "shine",
        "brightly",
        "white sea waves"
      ]
    },
    {
      "id": "u12-s8",
      "text": "The lovely blue of the sky always gives me a calm feeling.",
      "paragraphId": "u12-p3",
      "keywords": [
        "blue",
        "sky",
        "calm feeling"
      ]
    },
    {
      "id": "u12-s9",
      "text": "It is like a great sea above the plateau.",
      "paragraphId": "u12-p3",
      "keywords": [
        "great sea",
        "above",
        "plateau"
      ]
    },
    {
      "id": "u12-s10",
      "text": "And words can't express my love for the rivers and lakes.",
      "paragraphId": "u12-p3",
      "keywords": [
        "words",
        "express",
        "love",
        "rivers",
        "lakes"
      ]
    },
    {
      "id": "u12-s11",
      "text": "There are a hundred kinds of blue in the water.",
      "paragraphId": "u12-p3",
      "keywords": [
        "hundred kinds",
        "blue",
        "water"
      ]
    },
    {
      "id": "u12-s12",
      "text": "Our grasslands, forests and fields are all green.",
      "paragraphId": "u12-p4",
      "keywords": [
        "grasslands",
        "forests",
        "fields",
        "green"
      ]
    },
    {
      "id": "u12-s13",
      "text": "That's my favourite colour.",
      "paragraphId": "u12-p4",
      "keywords": [
        "favourite",
        "colour"
      ]
    },
    {
      "id": "u12-s14",
      "text": "It means hope because it is the colour of life.",
      "paragraphId": "u12-p4",
      "keywords": [
        "means",
        "hope",
        "colour of life"
      ]
    },
    {
      "id": "u12-s15",
      "text": "But green is not just the colour of nature now.",
      "paragraphId": "u12-p4",
      "keywords": [
        "green",
        "colour of nature"
      ]
    },
    {
      "id": "u12-s16",
      "text": "Trains are running through the plateau.",
      "paragraphId": "u12-p4",
      "keywords": [
        "trains",
        "running",
        "plateau"
      ]
    },
    {
      "id": "u12-s17",
      "text": "They are this beautiful colour, too.",
      "paragraphId": "u12-p4",
      "keywords": [
        "beautiful",
        "colour"
      ]
    },
    {
      "id": "u12-s18",
      "text": "The plateau is quieter than the big cities.",
      "paragraphId": "u12-p5",
      "keywords": [
        "plateau",
        "quieter",
        "big cities"
      ]
    },
    {
      "id": "u12-s19",
      "text": "We have fewer shops and restaurants.",
      "paragraphId": "u12-p5",
      "keywords": [
        "fewer",
        "shops",
        "restaurants"
      ]
    },
    {
      "id": "u12-s20",
      "text": "But we have the best presents from nature.",
      "paragraphId": "u12-p5",
      "keywords": [
        "best presents",
        "nature"
      ]
    },
    {
      "id": "u12-s21",
      "text": "In my heart, it's better than any other place.",
      "paragraphId": "u12-p5",
      "keywords": [
        "heart",
        "better",
        "any other place"
      ]
    },
    {
      "id": "u12-s22",
      "text": "I'm proud to say that I'm from one of the most beautiful places in the world.",
      "paragraphId": "u12-p5",
      "keywords": [
        "proud",
        "most beautiful places",
        "world"
      ]
    }
  ],
