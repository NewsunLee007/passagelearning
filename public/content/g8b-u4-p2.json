      "id": "reading-q1",
      "type": "single_choice",
      "stem": "What happened to the author 12 years ago?",
      "options": [
        "A. She became a nurse",
        "B. She was saved in an earthquake",
        "C. She met Ye Man in college",
        "D. She moved to another city"
