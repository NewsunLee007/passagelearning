  "readingQuestions": [
    {
      "id": "reading-q1",
      "type": "single_choice",
      "stem": "Why can people lie on the surface of the Dead Sea?",
      "options": [
        "A. Because it is a lake",
        "B. Because it is saltier than any sea",
        "C. Because it is dead",
        "D. Because it is small"
      ],
      "answer": "B. Because it is saltier than any sea",
      "rationaleZh": "文中提到：I’m saltier than any sea, so people can lie on my surface."
    },
    {
      "id": "reading-q2",
      "type": "single_choice",
      "stem": "What is the main problem for the Dead Sea now?",
      "options": [
        "A. Too many plants",
        "B. Too much rain",
        "C. Water level is going down",
        "D. Too many fish"
      ],
      "answer": "C. Water level is going down",
      "rationaleZh": "文中提到：My water level is going down. I am becoming smaller year by year."
    },
    {
      "id": "reading-q3",
      "type": "single_choice",
      "stem": "How many species in Madagascar rainforest find it their only home?",
      "options": [
        "A. 20%",
        "B. 50%",
        "C. 80%",
        "D. 100%"
      ],
      "answer": "C. 80%",
      "rationaleZh": "文中提到：For 80% of them, I’m their only home in the world."
    },
    {
      "id": "reading-q4",
      "type": "single_choice",
      "stem": "Why are people cutting down trees in the rainforest?",
      "options": [
        "A. For wood and farming",
        "B. To make rain",
        "C. To save monkeys",
        "D. To build glaciers"
      ],
      "answer": "A. For wood and farming",
      "rationaleZh": "文中提到：people are cutting down my trees for wood and to make space for farming."
    },
    {
      "id": "reading-q5",
      "type": "single_choice",
      "stem": "How many glaciers are there in the Glacier National Park now?",
      "options": [
        "A. 150",
        "B. 200",
        "C. 25",
        "D. 100"
      ],
      "answer": "C. 25",
      "rationaleZh": "文中提到：Two hundred years ago, there were about 150 glaciers. But now, there are around 25."
    }
  ],
