  "sentences": [
    {
      "id": "u13-s1",
      "text": "The Dead Sea could die!",
      "paragraphId": "u13-p1",
      "keywords": [
        "Dead Sea",
        "die"
      ]
    },
    {
      "id": "u13-s2",
      "text": "I'm not a sea but a lake, and I lie at the world's lowest surface.",
      "paragraphId": "u13-p1",
      "keywords": [
        "lake",
        "lowest surface"
      ]
    },
    {
      "id": "u13-s3",
      "text": "I'm saltier than any sea.",
      "paragraphId": "u13-p1",
      "keywords": [
        "saltier",
        "sea"
      ]
    },
    {
      "id": "u13-s4",
      "text": "You can even lie on my water and read a book!",
      "paragraphId": "u13-p1",
      "keywords": [
        "lie on",
        "read"
      ]
    },
    {
      "id": "u13-s5",
      "text": "Rivers flow into me.",
      "paragraphId": "u13-p1",
      "keywords": [
        "Rivers",
        "flow into"
      ]
    },
    {
      "id": "u13-s6",
      "text": "But now people are taking too much water from them.",
      "paragraphId": "u13-p1",
      "keywords": [
        "taking",
        "water"
      ]
    },
    {
      "id": "u13-s7",
      "text": "Take less water, or I'll dry up within the next 100 years.",
      "paragraphId": "u13-p1",
      "keywords": [
        "dry up",
        "100 years"
      ]
    },
    {
      "id": "u13-s8",
      "text": "Rainforest - forest ≠ rain",
      "paragraphId": "u13-p2",
      "keywords": [
        "Rainforest",
        "forest",
        "rain"
      ]
    },
    {
      "id": "u13-s9",
      "text": "I'm the rainforest of Madagascar.",
      "paragraphId": "u13-p2",
      "keywords": [
        "rainforest",
        "Madagascar"
      ]
    },
    {
      "id": "u13-s10",
      "text": "As my name suggests, I make rain for my plants and animals, such as monkeys, snakes and many kinds of flowers.",
      "paragraphId": "u13-p2",
      "keywords": [
        "make rain",
        "plants",
        "animals"
      ]
    },
    {
      "id": "u13-s11",
      "text": "For 80% of them, I'm their only home in the world.",
      "paragraphId": "u13-p2",
      "keywords": [
        "80%",
        "only home"
      ]
    },
    {
      "id": "u13-s12",
      "text": "However, people are cutting down my trees for wood and to make space for farming.",
      "paragraphId": "u13-p2",
      "keywords": [
        "cutting down",
        "trees",
        "farming"
      ]
    },
    {
      "id": "u13-s13",
      "text": "Please stop it.",
      "paragraphId": "u13-p2",
      "keywords": [
        "stop"
      ]
    },
    {
      "id": "u13-s14",
      "text": "I'm disappearing.",
      "paragraphId": "u13-p2",
      "keywords": [
        "disappearing"
      ]
    },
    {
      "id": "u13-s15",
      "text": "If Frozen turns into Waterworld...",
      "paragraphId": "u13-p3",
      "keywords": [
        "Frozen",
        "Waterworld"
      ]
    },
    {
      "id": "u13-s16",
      "text": "I'm a glacier at the Glacier National Park in America.",
      "paragraphId": "u13-p3",
      "keywords": [
        "glacier",
        "Glacier National Park",
        "America"
      ]
    },
    {
      "id": "u13-s17",
      "text": "It's a land full of ice and snow.",
      "paragraphId": "u13-p3",
      "keywords": [
        "land",
        "ice",
        "snow"
      ]
    },
    {
      "id": "u13-s18",
      "text": "Do you want to explore the white world in the film Frozen?",
      "paragraphId": "u13-p3",
      "keywords": [
        "explore",
        "white world",
        "film Frozen"
      ]
    },
    {
      "id": "u13-s19",
      "text": "Then my home is the best choice.",
      "paragraphId": "u13-p3",
      "keywords": [
        "home",
        "best choice"
      ]
    },
    {
      "id": "u13-s20",
      "text": "Two hundred years ago, there were about 150 glaciers.",
      "paragraphId": "u13-p3",
      "keywords": [
        "200 years ago",
        "150 glaciers"
      ]
    },
    {
      "id": "u13-s21",
      "text": "But now, there are around 25.",
      "paragraphId": "u13-p3",
      "keywords": [
        "now",
        "25"
      ]
    },
    {
      "id": "u13-s22",
      "text": "Please stop climate change.",
      "paragraphId": "u13-p3",
      "keywords": [
        "stop",
        "climate change"
      ]
    },
    {
      "id": "u13-s23",
      "text": "I'm turning into Waterworld!",
      "paragraphId": "u13-p3",
      "keywords": [
        "turning into",
        "Waterworld"
      ]
    }
  ],
